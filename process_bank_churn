def scale_new_data(df: pd.DataFrame, scaler: MinMaxScaler, cols_to_scale: List[str]) -> pd.DataFrame:
    """
    Масштабує числові ознаки у нових даних, використовуючи попередньо навчений scaler.

    Args:
        df (pd.DataFrame): Новий DataFrame для масштабування.
        scaler (MinMaxScaler): Попередньо навчений об’єкт MinMaxScaler.
        cols_to_scale (List[str]): Колонки, які потрібно масштабувати.

    Returns:
        pd.DataFrame: DataFrame із масштабованими числовими ознаками.
    """
    df_new = df.copy()
    df_new[cols_to_scale] = scaler.transform(df_new[cols_to_scale])
    return df_new


def encode_new_geography(df: pd.DataFrame, encoder: OneHotEncoder) -> pd.DataFrame:
    """
    One-hot кодує колонку 'Geography' у новому наборі даних за допомогою попередньо навченного encoder.

    Args:
        df (pd.DataFrame): Новий DataFrame з колонкою 'Geography'.
        encoder (OneHotEncoder): Попередньо навчений об’єкт OneHotEncoder.

    Returns:
        pd.DataFrame: DataFrame із доданими one-hot колонками.
    """
    df = df.copy()
    encoded_cols = encoder.get_feature_names_out(['Geography']).tolist()
    df[encoded_cols] = encoder.transform(df[['Geography']])
    df = df.drop('Geography', axis=1)
    
    return df


def preprocess_new_data(df: pd.DataFrame, encoder: OneHotEncoder, scaler: MinMaxScaler) -> pd.DataFrame:
    """
    Повна попередня обробка для нових (невідомих) даних:
    - визначення числових колонок
    - масштабування
    - one-hot кодування категоріальної ознаки 'Geography'

    Args:
        df (pd.DataFrame): Новий DataFrame для обробки.
        encoder (OneHotEncoder): Попередньо навчений OneHotEncoder.
        scaler (MinMaxScaler): Попередньо навчений MinMaxScaler.

    Returns:
        pd.DataFrame: Оброблений DataFrame, готовий до передбачення.
    """
    df = encode_gender(df)
    numeric_cols, _ = get_column_types(df)
    cols_to_scale = get_columns_for_scaling(numeric_cols)
    df = scale_new_data(df, scaler, cols_to_scale)
    df = encode_new_geography(df, encoder)    
    df = df.drop('Surname', axis=1)
    return df


